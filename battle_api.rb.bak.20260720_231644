# encoding: UTF-8

# 발송 직전 문자열을 UTF-8로 통일합니다.
# 시트, API 응답, 환경변수 등에서 서로 다른 인코딩의 문자열이
# 섞일 때 Mastodon 발송이 실패하는 것을 방지합니다.
def force_utf8(value)
  str = value.to_s.dup

  if str.encoding == Encoding::ASCII_8BIT
    str = str.force_encoding('UTF-8')
  end

  unless str.valid_encoding?
    str = str.encode(
      'UTF-8',
      invalid: :replace,
      undef: :replace,
      replace: '?'
    )
  end

  str
end

def post_status_raw(text, visibility:, reply_to_id: nil)
  text = force_utf8(text)
  visibility = force_utf8(visibility)

  reply_to_id =
    reply_to_id.nil? ? nil : force_utf8(reply_to_id)
  uri = URI("#{ENV['MASTODON_BASE_URL']}/api/v1/statuses")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  http.open_timeout = 10
  http.read_timeout = 10

  req = Net::HTTP::Post.new(uri)
  req['Authorization'] = "Bearer #{ENV['BATTLE_TOKEN']}"
  req.set_form_data(
    status: text,
    visibility: visibility,
    in_reply_to_id: reply_to_id
  )

  res = http.request(req)
  unless res.code.to_i.between?(200, 299)
    puts "[전투봇 오류] 툿 발송 실패: #{res.code} #{res.body}"
    return nil
  end

  JSON.parse(res.body)
rescue => e
  puts "[전투봇 오류] 툿 발송 예외: #{e.class}: #{e.message}"
  nil
end

# 인스턴스 글자 제한을 넘는 툿은 줄 단위로 분할해
# 답글 스레드로 이어 발송합니다.
#
# 기본값은 여유를 둔 950자이며 .env에서 조절할 수 있습니다.
# 예: TOOT_MAX_CHARS=900
TOOT_MAX_CHARS = (ENV['TOOT_MAX_CHARS'] || '950').to_i

def split_toot_text(text, limit = TOOT_MAX_CHARS)
  text = force_utf8(text)

  return [text] if limit <= 0 || text.length <= limit

  lines = text.split("\n", -1)

  # 첫 줄이 멘션 목록이면 이후 모든 조각에도 반복합니다.
  header =
    lines.first.to_s.start_with?('@') ? lines.first.strip : nil

  chunks = []
  current = ''

  lines.each do |line|
    candidate =
      current.empty? ? line : "#{current}\n#{line}"

    if candidate.length <= limit
      current = candidate
      next
    end

    chunks << current unless current.empty?

    base = header ? "#{header}\n" : ''

    if (base + line).length <= limit
      current = base + line
      next
    end

    # 한 줄 자체가 제한보다 길면 문자 단위로 강제 분할합니다.
    room = [limit - base.length, 1].max
    pieces = line.chars.each_slice(room).map(&:join)

    pieces.each_with_index do |piece, index|
      if index.positive? && !current.empty?
        chunks << current
      end

      current = base + piece
    end
  end

  chunks << current unless current.empty?
  chunks
end

# === 전투 게시글 2~3개 분할 시작 ===

BATTLE_STATUS_LIMIT = 480 unless defined?(BATTLE_STATUS_LIMIT)
BATTLE_THREAD_MAX_PARTS = 3 unless defined?(BATTLE_THREAD_MAX_PARTS)

def force_utf8(value)
  value.to_s
       .encode('UTF-8', invalid: :replace, undef: :replace, replace: '�')
       .scrub
end

def split_battle_status(text, limit: BATTLE_STATUS_LIMIT)
  clean_text = force_utf8(text).gsub(/\r\n?/, "\n").strip
  return [] if clean_text.empty?
  return [clean_text] if clean_text.length <= limit

  # 번호 표시에 필요한 길이를 미리 확보합니다.
  content_limit = limit - 8

  required_parts = (clean_text.length.to_f / content_limit).ceil

  # 긴 글은 가급적 2개, 정말 필요한 경우에만 3개로 나눕니다.
  part_count = required_parts <= 2 ? 2 : 3

  if required_parts > BATTLE_THREAD_MAX_PARTS
    raise ArgumentError,
          "전투 게시글이 너무 깁니다: " \
          "#{clean_text.length}자 " \
          "(최대 약 #{content_limit * BATTLE_THREAD_MAX_PARTS}자)"
  end

  lines = clean_text.lines(chomp: true)
  parts = []
  current = +""

  lines.each do |line|
    candidate = current.empty? ? line : "#{current}\n#{line}"

    if candidate.length <= content_limit
      current = candidate
      next
    end

    parts << current unless current.empty?
    current = +""

    # 한 줄 자체가 긴 경우 글자 수 기준으로 나눕니다.
    remaining = line.dup

    while remaining.length > content_limit
      parts << remaining.slice!(0, content_limit)
    end

    current = remaining
  end

  parts << current unless current.empty?

  # 줄 단위 분리 결과가 목표 개수보다 많으면 글자 기준으로 다시 균등 분할합니다.
  if parts.length > part_count
    target_size = (clean_text.length.to_f / part_count).ceil

    parts = []
    remaining = clean_text.dup

    while remaining.length > target_size && parts.length < part_count - 1
      cut_at = remaining.rindex("\n", target_size)

      # 너무 앞에서 잘리는 경우에는 목표 글자 수 위치를 사용합니다.
      cut_at = target_size if cut_at.nil? || cut_at < target_size / 2

      part = remaining.slice!(0, cut_at).strip
      remaining = remaining.sub(/\A\n+/, '')

      parts << part
    end

    parts << remaining.strip unless remaining.strip.empty?
  end

  if parts.length > BATTLE_THREAD_MAX_PARTS ||
     parts.any? { |part| part.length > content_limit }
    raise ArgumentError,
          "전투 게시글을 최대 #{BATTLE_THREAD_MAX_PARTS}개 안에 " \
          "분할할 수 없습니다."
  end

  total = parts.length

  parts.each_with_index.map do |part, index|
    total > 1 ? "(#{index + 1}/#{total})\n#{part}" : part
  end
end

def post_battle_thread(text, dm_mode, reply_id)
  visibility = dm_mode ? 'direct' : 'public'
  statuses = split_battle_status(text)

  return nil if statuses.empty?

  current_reply_id = reply_id
  last_result = nil

  statuses.each do |status_text|
    last_result = post_status_raw(
      status_text,
      visibility: visibility,
      reply_to_id: current_reply_id
    )

    unless last_result
      puts "[전투봇 오류] 전투 게시글 스레드 발송 중단"
      return nil
    end

    # 다음 게시글을 바로 앞 게시글의 답글로 연결합니다.
    current_reply_id = last_result['id']
  end

  last_result
rescue ArgumentError => e
  puts "[전투봇 오류] 전투 게시글 분할 실패: #{e.message}"
  nil
rescue => e
  puts "[전투봇 오류] 전투 게시글 발송 예외: #{e.class}: #{e.message}"
  nil
end

# === 전투 게시글 2~3개 분할 끝 ===
def fetch_public_statuses
  uri = URI("#{ENV['MASTODON_BASE_URL']}/api/v1/timelines/public?local=true")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  http.open_timeout = 10
  http.read_timeout = 10

  req = Net::HTTP::Get.new(uri)
  req['Authorization'] = "Bearer #{ENV['BATTLE_TOKEN']}"

  res = http.request(req)
  return [] unless res.code == '200'

  JSON.parse(res.body)
rescue => e
  puts "[전투봇 오류] 공개 타임라인 조회 실패: #{e.class}: #{e.message}"
  []
end

def fetch_conversations
  uri = URI("#{ENV['MASTODON_BASE_URL']}/api/v1/conversations")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  http.open_timeout = 10
  http.read_timeout = 10

  req = Net::HTTP::Get.new(uri)
  req['Authorization'] = "Bearer #{ENV['BATTLE_TOKEN']}"

  res = http.request(req)
  return [] unless res.code == '200'

  JSON.parse(res.body)
rescue => e
  puts "[전투봇 오류] DM 조회 실패: #{e.class}: #{e.message}"
  []
end

def fetch_notifications(since_id: nil)
  uri = URI("#{ENV['MASTODON_BASE_URL']}/api/v1/notifications")
  params = { limit: 30 }
  params[:since_id] = since_id.to_s if since_id
  uri.query = URI.encode_www_form(params)

  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  http.open_timeout = 10
  http.read_timeout = 10

  req = Net::HTTP::Get.new(uri)
  req['Authorization'] = "Bearer #{ENV['BATTLE_TOKEN']}"

  res = http.request(req)
  return [] unless res.code == '200'

  JSON.parse(res.body).select { |n| n['type'] == 'mention' && n['status'] }
rescue => e
  puts "[전투봇 오류] 알림 조회 실패: #{e.class}: #{e.message}"
  []
end

def snapshot_current_dm_ids(processed_dm_ids)
  fetch_conversations.each do |conv|
    last_status = conv['last_status']
    next unless last_status && last_status['id']
    processed_dm_ids.add(last_status['id'])
  end
end

def snapshot_current_notification_ids(processed_notification_ids)
  fetch_notifications.each do |n|
    processed_notification_ids.add(n['id']) if n['id']
  end
end
